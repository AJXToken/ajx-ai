:global(html), :global(body) {
  height: 100%;
  overflow: hidden; /* ✅ poistaa oikean reunan turhan scrollbar */
}

.shell {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  color: #111;
  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial,
    "Apple Color Emoji", "Segoe UI Emoji";
}

.bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(900px 650px at 20% 10%, rgba(0,0,0,0.05), transparent 60%),
    radial-gradient(900px 650px at 80% 20%, rgba(0,0,0,0.04), transparent 60%),
    linear-gradient(180deg, #f6f7f9, #eef0f3 55%, #e9ebef);
}

.layout {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 320px 1fr;
  height: 100vh;      /* ✅ lukitse koko näkymä */
  min-height: 0;
}

/* Sidebar */
.sidebar {
  border-right: 1px solid rgba(0,0,0,0.10);
  background: rgba(255,255,255,0.86);
  backdrop-filter: blur(14px);
  display: grid;
  grid-template-rows: auto 1fr auto;
  transition: width 0.2s ease, transform 0.2s ease;
  height: 100vh;
  overflow: hidden;   /* ✅ ei body-scrollia */
  min-height: 0;
}

.sidebarOpen { width: 320px; }
.sidebarClosed { width: 0px; transform: translateX(-100%); }

.sidebarTop {
  padding: 14px 14px 10px;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  display: grid;
  gap: 12px;
}

.brandMini { display: flex; gap: 10px; align-items: center; }

.logoMini {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  font-weight: 900;
  letter-spacing: 0.5px;
  background: rgba(0,0,0,0.06);
  border: 1px solid rgba(0,0,0,0.10);
  color: #111;
}

.brandMiniTitle { font-size: 14px; font-weight: 900; color: #111; }
.brandMiniSub { font-size: 12px; opacity: 0.65; margin-top: 2px; color: #111; }

.btnPrimarySmall {
  appearance: none;
  border: 1px solid rgba(0,0,0,0.18);
  background: #111;
  color: #fff;
  padding: 10px 12px;
  border-radius: 14px;
  font-weight: 900;
  cursor: pointer;
}
.btnPrimarySmall:hover { filter: brightness(1.05); }

/* ✅ vasen lista scrollaa itse */
.threadList {
  padding: 10px;
  overflow-y: auto;
  min-height: 0;
}

.threadItem {
  border: 1px solid rgba(0,0,0,0.10);
  background: rgba(255,255,255,0.72);
  border-radius: 16px;
  padding: 10px;
  margin: 10px 0;
  cursor: pointer;
  transition: background 0.12s ease, border 0.12s ease;
}
.threadItem:hover {
  background: rgba(255,255,255,0.90);
  border-color: rgba(0,0,0,0.14);
}

.threadActive {
  border-color: rgba(0,0,0,0.22);
  background: rgba(255,255,255,0.95);
}

.threadTitle {
  font-weight: 900;
  font-size: 13px;
  margin-bottom: 6px;
  color: #111;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.threadMeta {
  display: flex;
  gap: 8px;
  font-size: 11.5px;
  opacity: 0.70;
  margin-bottom: 8px;
  color: #111;
}

.threadActions { display: flex; gap: 8px; }

.btnTiny, .btnTinyDanger {
  appearance: none;
  border: 1px solid rgba(0,0,0,0.14);
  background: rgba(0,0,0,0.04);
  color: #111;
  padding: 6px 8px;
  border-radius: 12px;
  font-weight: 850;
  font-size: 11px;
  cursor: pointer;
}
.btnTiny:hover, .btnTinyDanger:hover {
  background: rgba(0,0,0,0.07);
  border-color: rgba(0,0,0,0.22);
}

.sidebarBottom {
  padding: 12px 12px 14px;
  border-top: 1px solid rgba(0,0,0,0.08);
}

.sidebarPills { display: flex; flex-wrap: wrap; gap: 8px; }

.pill {
  font-size: 12px;
  padding: 6px 10px;
  border-radius: 999px;
  border: 1px solid rgba(0,0,0,0.12);
  background: rgba(255,255,255,0.75);
  letter-spacing: 0.3px;
  color: #111;
  font-weight: 900;
}

.pill_free { box-shadow: 0 0 0 1px rgba(0,0,0,0.03) inset; }
.pill_lite { background: rgba(0,0,0,0.03); border-color: rgba(0,0,0,0.14); }
.pill_basic { background: rgba(0,0,0,0.06); border-color: rgba(0,0,0,0.16); }
.pill_pro { background: rgba(0,0,0,0.08); border-color: rgba(0,0,0,0.18); }
.pill_partner { background: rgba(0,0,0,0.10); border-color: rgba(0,0,0,0.20); }
.pill_focus { background: rgba(0,0,0,0.12); border-color: rgba(0,0,0,0.22); }

.sidebarUsage {
  margin-top: 8px;
  font-size: 12px;
  opacity: 0.78;
  color: #111;
}

/* Main */
.mainPane {
  display: grid;
  grid-template-rows: auto 1fr auto;
  height: 100vh;
  overflow: hidden;
  min-width: 0;
  min-height: 0;
}

.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  backdrop-filter: blur(12px);
  background: rgba(255,255,255,0.82);
  border-bottom: 1px solid rgba(0,0,0,0.10);
}

.topLeft { display: flex; align-items: center; gap: 10px; }
.topTitle { min-width: 0; }

.title { font-size: 16px; font-weight: 900; letter-spacing: 0.2px; color: #111; }
.subtitle { margin-top: 2px; font-size: 12px; opacity: 0.70; color: #111; }

.actions { display: flex; gap: 10px; }

.btnGhost {
  appearance: none;
  border: 1px solid rgba(0,0,0,0.14);
  background: rgba(0,0,0,0.04);
  color: #111;
  padding: 10px 12px;
  border-radius: 12px;
  font-weight: 800;
  letter-spacing: 0.3px;
  cursor: pointer;
}
.btnGhost:hover {
  background: rgba(0,0,0,0.06);
  border-color: rgba(0,0,0,0.18);
}

.main {
  display: grid;
  place-items: center;
  padding: 18px 14px 22px;
  min-height: 0;
  overflow: hidden;
}

.chatCard {
  width: min(1040px, 96vw);
  height: min(74vh, 740px);
  display: grid;
  grid-template-rows: 1fr auto;
  border-radius: 22px;
  border: 1px solid rgba(0,0,0,0.12);
  background: #ffffff;
  box-shadow: 0 18px 55px rgba(0,0,0,0.12);
  overflow: hidden;
  min-height: 0;
}

/* ✅ viestit scrollaa */
.msgList {
  padding: 18px 18px 10px;
  overflow-y: auto;
  background: #ffffff;
  min-height: 0;
}

.msgRow {
  display: grid;
  grid-template-columns: 40px minmax(0, 1fr) 40px;
  align-items: end;
  gap: 10px;
  margin: 10px 0;
}

/* käytössä page.tsx:ssa */
.rowAi { /* used */ }
.rowUser { /* used */ }

.rightSlot { width: 40px; height: 1px; }

.avatarAi, .avatarUser {
  width: 34px;
  height: 34px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  font-weight: 900;
  border: 1px solid rgba(0,0,0,0.12);
  background: #f4f4f5;
  color: #111;
}

.bubble {
  border-radius: 18px;
  padding: 12px 14px;
  border: 1px solid rgba(0,0,0,0.12);
  line-height: 1.45;
  font-size: 14.5px;
  display: inline-block;
  width: fit-content;
  max-width: min(76ch, 100%);
  min-width: 10ch;
}

.bubbleAi { background: #ffffff; }
.bubbleUser { background: #f2f2f3; }

.bubbleText {
  color: #111;
  opacity: 0.96;
  white-space: pre-wrap;
  overflow-wrap: break-word;
}

/* ✅ inlineImage – SIIRRETTY ulos @media:sta, toimii aina */
.inlineImage {
  max-width: 100%;
  height: auto;
  display: block;
  border-radius: 14px;
  border: 1px solid rgba(0,0,0,0.10);
  box-shadow: 0 10px 30px rgba(0,0,0,0.10);
}

/* ✅ composer pysyy paikallaan */
.composer {
  position: sticky;
  bottom: 0;
  padding: 14px;
  border-top: 1px solid rgba(0,0,0,0.12);
  background: #f0f0f1;
}

/* ✅ UUSI: Action Bar */
.actionBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 10px;
  padding: 10px 12px;
  border-radius: 16px;
  border: 1px solid rgba(0,0,0,0.10);
  background: rgba(255,255,255,0.60);
  backdrop-filter: blur(8px);
}

.actionLeft {
  display: flex;
  gap: 8px;
  align-items: center;
}

.actionRight {
  display: flex;
  gap: 8px;
  align-items: center;
}

.actionBtn {
  border-radius: 12px;
  padding: 10px 12px;
  font-weight: 900;
  font-size: 13px;
  border: 1px solid rgba(0,0,0,0.14);
  background: rgba(0,0,0,0.04);
  color: #111;
  cursor: pointer;
  user-select: none;
}
.actionBtn:hover {
  background: rgba(0,0,0,0.06);
  border-color: rgba(0,0,0,0.18);
}

.actionBtnActive {
  background: rgba(0,0,0,0.08);
  border-color: rgba(0,0,0,0.18);
}

.actionBtnDisabled {
  color: rgba(0,0,0,0.35);
  cursor: not-allowed;
  opacity: 0.95;
}
.actionBtnDisabled:hover {
  background: rgba(0,0,0,0.04);
  border-color: rgba(0,0,0,0.14);
}

.actionPill {
  font-size: 12px;
  font-weight: 900;
  color: rgba(0,0,0,0.55);
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(0,0,0,0.04);
  border: 1px solid rgba(0,0,0,0.08);
}

/* ✅ UUSI: Voice-hint */
.voiceHint {
  margin-bottom: 10px;
  padding: 10px 12px;
  border-radius: 14px;
  border: 1px solid rgba(0,0,0,0.10);
  background: rgba(0,0,0,0.03);
  font-size: 13px;
  font-weight: 800;
  color: rgba(0,0,0,0.75);
}

.composerInner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 10px;
  align-items: center;
}

.input {
  width: 100%;
  resize: none;
  outline: none;
  border-radius: 16px;
  padding: 12px;
  border: 1px solid rgba(0,0,0,0.18);
  background: #ffffff;
  color: #111;
  font-size: 14.5px;
  line-height: 1.35;
}
.input::placeholder { color: rgba(0,0,0,0.55); }

.composerRight { display: flex; gap: 10px; align-items: center; }

.btnPrimary {
  appearance: none;
  border: 1px solid rgba(0,0,0,0.25);
  background: #111;
  color: #fff;
  padding: 12px 16px;
  border-radius: 16px;
  font-weight: 900;
  cursor: pointer;
}
.btnPrimary:hover { filter: brightness(1.05); }
.btnPrimary:disabled { opacity: 0.45; cursor: not-allowed; }

.hint {
  margin-top: 10px;
  font-size: 12px;
  color: rgba(0,0,0,0.62);
  padding-left: 2px;
}

/* ✅ UUSI: Modal */
.modalOverlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  z-index: 9999;
}

.modalCard {
  width: min(520px, 100%);
  border-radius: 18px;
  background: #fff;
  border: 1px solid rgba(0,0,0,0.12);
  box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  padding: 16px;
}

.modalHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.modalTitle {
  font-size: 16px;
  font-weight: 1000;
  color: #111;
}

.modalClose {
  border-radius: 12px;
  padding: 8px 10px;
  font-weight: 900;
  border: 1px solid rgba(0,0,0,0.14);
  background: rgba(0,0,0,0.04);
  cursor: pointer;
  color: #111;
}
.modalClose:hover {
  background: rgba(0,0,0,0.06);
  border-color: rgba(0,0,0,0.18);
}

.modalBody {
  margin-top: 10px;
  font-size: 13px;
  color: rgba(0,0,0,0.78);
  font-weight: 750;
  line-height: 1.45;
}

.modalFooter {
  margin-top: 12px;
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}

.modalBtn {
  border-radius: 12px;
  padding: 10px 12px;
  font-weight: 900;
  border: 1px solid rgba(0,0,0,0.14);
  background: rgba(0,0,0,0.04);
  cursor: pointer;
  color: #111;
}
.modalBtn:hover {
  background: rgba(0,0,0,0.06);
  border-color: rgba(0,0,0,0.18);
}

.footer {
  display: flex;
  justify-content: flex-start;
  padding: 12px 18px 16px;
  font-size: 12px;
  color: rgba(0,0,0,0.60);
}

.footerLeft {
  border: 1px solid rgba(0,0,0,0.10);
  background: rgba(255,255,255,0.65);
  padding: 6px 10px;
  border-radius: 999px;
}

/* responsive */
@media (max-width: 980px) {
  .layout { grid-template-columns: 1fr; }

  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 50;
    width: 320px;
  }
  .sidebarClosed { transform: translateX(-100%); }

  .main { padding: 14px 10px 18px; }
}