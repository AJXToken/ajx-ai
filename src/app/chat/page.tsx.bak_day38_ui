          }

          .ajxQuickRow {
            flex-wrap: nowrap;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
            scroll-behavior: smooth;
          }

          .ajxParagraph,
          .ajxRichList,
          .ajxRichListOrdered,
          .ajxSummaryText {
            line-height: 1.72;
          }

          .ajxCodePre {
            font-size: 12px;
          }

          .ajxTopHelp {
            display: none;
