            monospace;
        }

        @media (max-width: 980px) {
          .ajxTopControls {
            gap: 8px;
            width: 100%;
            justify-content: flex-start;
          }

          .ajxControlGroup {
            padding: 5px;
          }

          .ajxQuickWrap {
