          gap: 8px;
          padding: 6px;
          border-radius: 16px;
          border: 1px solid rgba(11, 13, 18, 0.08);
          background: rgba(255, 255, 255, 0.62);
          backdrop-filter: blur(12px);
          box-shadow: 0 10px 24px rgba(11, 13, 18, 0.08);
          max-width: 100%;
        }

        .ajxControlLabel {
          font-size: 12px;
          font-weight: 950;
          letter-spacing: 0.2px;
