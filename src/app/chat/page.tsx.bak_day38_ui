          .ajxComposerHelp {
            display: inline-flex;
            padding: 0 12px;
            height: 46px;
            border-radius: 16px;
          }

          .ajxComposerActions {
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: end;
